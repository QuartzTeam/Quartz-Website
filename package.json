{
  "name": "quartz-website",
  "version": "1.0.0",
  "private": true,
  "description": "Static website and markdown documentation for Quartz.",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
